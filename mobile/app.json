{
  "expo": {
    "name": "SportSync",
    "slug": "sportsync-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.sportsync.mobile",
      "versionCode": 1,
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#090d21"
      }
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow SportSync to access your photos to set a profile picture."
        }
      ]
    ],
    "extra": {
      "demoMode": false,
      "apiUrl": "https://apisportsync.xyz",
      "eas": {
        "projectId": "5b25aa27-1ed0-4e86-a992-03faf8b58f97"
      }
    },
    "owner": "abgrundschwarz"
  }
}
