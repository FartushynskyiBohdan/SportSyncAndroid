# Copy this file to .env and fill in your local backend address.
# .env is git-ignored — never commit the actual .env file.

# For Android emulator (default if this file is absent):
# EXPO_PUBLIC_API_URL=http://10.0.2.2:3000

# For a physical device on the same Wi-Fi, use your machine's LAN IP:
# EXPO_PUBLIC_API_URL=http://192.168.x.x:3000

# Use the built-in mocked walkthrough data only if the backend is unavailable:
# EXPO_PUBLIC_DEMO_MODE=true

# Your current LAN IP (run: ipconfig | findstr IPv4  or  hostname -I):
EXPO_PUBLIC_API_URL=http://YOUR_LAN_IP:3000
