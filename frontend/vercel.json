{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://apisportsync.xyz/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://apisportsync.xyz/uploads/:path*"
    },
    {
      "source": "/((?!assets/).*)",
      "destination": "/index.html"
    }
  ]
}
